# ── Personal data — never commit these ────────────────────────────────────────
# Everything you fill in lives in setup/. Those files are gitignored.
# setup/examples/ contains tracked example files — those are safe to commit.
setup/*.md
setup/config.json
setup/profile/

# ── Generated deployment artefacts — contain real tokens and personal URLs ────
# Both files are regenerated by scripts/build-and-deploy.sh at every deploy.
# They contain the WIDGET_TOKEN and your worker URLs — never commit them.
widget/index.html
setup/embed.html

# Claude Code project settings — contain absolute paths from the dev machine.
.claude/

# Legacy folders — gitignored in case they contain personal data.
knowledge/
profile/
config/
